# Discord Bot Token (from Discord Developer Portal)
DISCORD_TOKEN=your_bot_token_here

# Channel ID where application embeds are posted
DISCORD_CHANNEL_ID=1234567890123456789

# Optional: Role ID required to approve/deny (leave empty to allow all)
DISCORD_ADMIN_ROLE_ID=

# Velocity Admin API URL (internal Docker network)
VELOCITY_API_URL=http://velocity:8080

# Shared secret (must match Velocity config)
VELOCITY_SHARED_SECRET=your_shared_secret_here

# Webhook server settings
WEBHOOK_PORT=3000
WEBHOOK_HOST=0.0.0.0
